  "openapi_url": "http://172.20.1.175:7050/openapi.json",
  "docs_url": "http://172.20.1.175:7050/docs",
  "capabilities": [
    "Generate verified C# code examples for Aspose.PDF for .NET",
    "Browse build-validated examples organised by category (text, tables, forms, security, ...)",
    "Look up category-specific anti-patterns and API surface via per-category AGENTS.md",
    "Programmatically enumerate examples via index.json (root + per category)"
  ],
  "tools": [
    {
      "name": "agent_generate",
      "description": "Generate + validate-revise-retry C# example via /mcp/agent/generate (server-side retry loop, max_attempts up to 3)"
    },
    {
      "name": "agent_run",
      "description": "Older agent runner via /mcp/agent/run -- kept for compatibility with clients that haven't migrated to agent/generate"
    },
    {
      "name": "generate",
      "description": "Single-shot generation via /mcp/generate (no server-side retry) -- the bare endpoint"
    },
    {
      "name": "retrieve",
      "description": "Retrieve relevant Aspose.PDF API knowledge-base chunks via /mcp/retrieve (embedding + keyword hybrid)"
    }
  ],

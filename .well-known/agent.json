{
  "name": "Aspose.PDF for .NET Examples Agent",
  "description": "AI agent that generates, compiles, and validates C# code examples for Aspose.PDF for .NET 26.6.0. 2,684 build-verified examples across 34 categories.",
  "version": "26.6.0",
  "url": "https://github.com/aspose-pdf/agentic-net-examples.git",
  "api_base_url": "http://172.20.1.175:7050",
